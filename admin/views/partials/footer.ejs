<%- include('../partials/media') %>
  <script>
    let mediaTarget = null;
    let selectedMediaItem = null;

    let mediaCurrentPage = 1;
    let mediaTotalPages  = 1;
    let mediaLoaded      = false;

    window.addEventListener('load', () => {
      loadMedia(1);
    });


    // ✅ Open modal — accepts object: { urlInput, preview, titleInput, altInput, container, multiple }
    function openMedia(opts) {
      mediaTarget = opts;
      selectedMediaItem = null;

      // Reset UI
      document.getElementById('selectedMediaInfo').style.display = 'none';
      document.getElementById('btnInsertMedia').disabled = true;

      if (!mediaLoaded) {
        loadMedia(1);
      } else {
        loadMedia(mediaCurrentPage);
      }

      showMediaTab('library');
      new bootstrap.Modal(document.getElementById('mediaModal')).show();
    }

    // ✅ Load media from server (paginated, newest first)
    function loadMedia(page, forceReload = false) {
      page = page || 1;
      fetch('/admin/media?page=' + page)
        .then(res => res.json())
        .then(data => {
          mediaCurrentPage = data.page       || 1;
          mediaTotalPages  = data.totalPages || 1;
          mediaLoaded      = true;
          renderMedia(data.images || []);
        });
    }

    function renderMedia(images) {
      const grid = document.getElementById('mediaGrid');
      grid.innerHTML = '';

      const fragment = document.createDocumentFragment();

      images.forEach(img => {
        const div = document.createElement('div');
        div.className = 'media-thumb';
        div.style.cssText =
          'width:100px;height:100px;cursor:pointer;position:relative;border:2px solid transparent;border-radius:4px;overflow:hidden;';
        div.innerHTML = `
          <img
            src="${img.url}"
            loading="lazy"
            decoding="async"
            style="width:100%;height:100%;object-fit:cover;"
          />
        `;
        div.onclick = () => highlightMedia(img, div);
        fragment.appendChild(div);
      });

      grid.appendChild(fragment);

      // Render pagination below the grid
      renderMediaPagination();
    }

    function renderMediaPagination() {
      // Remove existing pagination if any
      const existing = document.getElementById('mediaPagination');
      if (existing) existing.remove();

      if (mediaTotalPages <= 1) return;

      const wrapper = document.createElement('div');
      wrapper.id = 'mediaPagination';
      wrapper.style.cssText = 'width:100%;display:flex;justify-content:center;align-items:center;gap:6px;padding:12px 0 4px;flex-wrap:wrap;';

      const btnStyle = (active) =>
        `padding:4px 10px;border-radius:4px;border:1px solid #dee2e6;background:${active ? '#0d6efd' : '#fff'};color:${active ? '#fff' : '#212529'};cursor:${active ? 'default' : 'pointer'};font-size:13px;`;

      // Prev button
      const prev = document.createElement('button');
      prev.textContent = '‹ Prev';
      prev.style.cssText = btnStyle(false) + (mediaCurrentPage === 1 ? 'opacity:0.4;pointer-events:none;' : '');
      prev.onclick = () => loadMedia(mediaCurrentPage - 1);
      wrapper.appendChild(prev);

      // Page number buttons (show a window around current page)
      const windowSize = 5;
      let start = Math.max(1, mediaCurrentPage - Math.floor(windowSize / 2));
      let end   = Math.min(mediaTotalPages, start + windowSize - 1);
      start = Math.max(1, end - windowSize + 1);

      if (start > 1) {
        const first = document.createElement('button');
        first.textContent = '1';
        first.style.cssText = btnStyle(false);
        first.onclick = () => loadMedia(1);
        wrapper.appendChild(first);
        if (start > 2) {
          const dots = document.createElement('span');
          dots.textContent = '…';
          dots.style.cssText = 'padding:4px 6px;font-size:13px;color:#6c757d;';
          wrapper.appendChild(dots);
        }
      }

      for (let p = start; p <= end; p++) {
        const btn = document.createElement('button');
        btn.textContent = p;
        btn.style.cssText = btnStyle(p === mediaCurrentPage);
        if (p !== mediaCurrentPage) btn.onclick = ((pg) => () => loadMedia(pg))(p);
        wrapper.appendChild(btn);
      }

      if (end < mediaTotalPages) {
        if (end < mediaTotalPages - 1) {
          const dots = document.createElement('span');
          dots.textContent = '…';
          dots.style.cssText = 'padding:4px 6px;font-size:13px;color:#6c757d;';
          wrapper.appendChild(dots);
        }
        const last = document.createElement('button');
        last.textContent = mediaTotalPages;
        last.style.cssText = btnStyle(false);
        last.onclick = () => loadMedia(mediaTotalPages);
        wrapper.appendChild(last);
      }

      // Next button
      const next = document.createElement('button');
      next.textContent = 'Next ›';
      next.style.cssText = btnStyle(false) + (mediaCurrentPage === mediaTotalPages ? 'opacity:0.4;pointer-events:none;' : '');
      next.onclick = () => loadMedia(mediaCurrentPage + 1);
      wrapper.appendChild(next);

      // Insert after grid
      const grid = document.getElementById('mediaGrid');
      grid.parentNode.insertBefore(wrapper, grid.nextSibling);
    }

    // ✅ Highlight selected — show title/alt in sidebar, enable Insert button
    function highlightMedia(img, el) {
      document.querySelectorAll('#mediaGrid .media-thumb').forEach(d => {
        d.style.border = '2px solid transparent';
      });
      el.style.border = '2px solid #0d6efd';

      selectedMediaItem = img;

      // Show info panel
      const info = document.getElementById('selectedMediaInfo');
      info.style.display = 'block';
      document.getElementById('selectedMediaPreview').src = img.url;
      document.getElementById('selectedMediaTitle').value = img.title || '';
      document.getElementById('selectedMediaAlt').value = img.alt || '';

      document.getElementById('btnInsertMedia').disabled = false;
    }

    // ✅ Insert selected image into form
    function insertSelectedMedia() {
      if (!mediaTarget || !selectedMediaItem) return;

      const img = selectedMediaItem;
      // Read title/alt from the editable fields in the modal
      const title = document.getElementById('selectedMediaTitle').value || img.title || '';
      const alt = document.getElementById('selectedMediaAlt').value || img.alt || '';

      if (!mediaTarget.multiple) {
        // ── SINGLE (featured image or variation image) ──────────────
        const urlEl = document.getElementById(mediaTarget.urlInput);
        if (urlEl) urlEl.value = img.url;

        if (mediaTarget.titleInput) {
          const tEl = document.getElementById(mediaTarget.titleInput);
          if (tEl) tEl.value = title;
        }
        if (mediaTarget.altInput) {
          const aEl = document.getElementById(mediaTarget.altInput);
          if (aEl) aEl.value = alt;
        }

        if (mediaTarget.preview) {
          const prev = document.getElementById(mediaTarget.preview);
          if (prev) {
            prev.innerHTML = `<img src="${img.url}" class="img-fluid rounded" style="max-height:150px;">`;
          }
        }

        bootstrap.Modal.getInstance(document.getElementById('mediaModal')).hide();

      } else {
        // ── MULTIPLE (gallery) ──────────────────────────────────────
        const container = mediaTarget.container
          ? document.getElementById(mediaTarget.container)
          : null;

        if (container) {
          const div = document.createElement('div');
          div.style.cssText = 'position:relative;width:70px;height:70px;margin:3px;';

          const urlName = mediaTarget.urlInput || 'gallery_image[]';
          const titleName = mediaTarget.titleInput || 'gallery_image_titles[]';
          const altName = mediaTarget.altInput || 'gallery_image_alts[]';

          // Append [] if not present
          const toArr = n => n.endsWith('[]') ? n : n + '[]';

          div.innerHTML = `
            <img src="${img.url}" style="width:70px;height:70px;object-fit:cover;border-radius:4px;" />
            <input type="hidden" name="${toArr(urlName)}"   value="${img.url}">
            <input type="hidden" name="${toArr(titleName)}" value="${title}">
            <input type="hidden" name="${toArr(altName)}"   value="${alt}">
            <button onclick="this.parentElement.remove()"
              class="btn btn-danger btn-sm position-absolute top-0 end-0 p-0"
              style="width:18px;height:18px;font-size:10px;line-height:1;">×</button>
          `;

          // Insert before the + button (first child)
          container.insertBefore(div, container.firstChild);
        }
        bootstrap.Modal.getInstance(document.getElementById('mediaModal')).hide();
      }
    }

    // ✅ Tabs
    function showMediaTab(tab) {
      document.getElementById('mediaLibraryTab').style.display = tab === 'library' ? 'block' : 'none';
      document.getElementById('mediaUploadTab').style.display = tab === 'upload' ? 'block' : 'none';
      document.getElementById('selectedMediaInfo').style.display = tab === 'upload' ? 'none' : 'block';
    }

    // ✅ Upload media — auto-select after upload
    function uploadMedia() {
      const input = document.getElementById('mediaUploadInput');
      const files = input.files;
      if (!files.length) return;

      const formData = new FormData();
      for (let f of files) formData.append('files', f);

      fetch('/admin/media/upload', { method: 'POST', body: formData })
        .then(r => r.json())
        .then(data => {
          input.value = '';
          showMediaTab('library');

          // Reload page 1 so newly uploaded images appear first
          mediaLoaded = false;
          loadMedia(1);

          // Auto-select the first uploaded file after grid renders
          if (data.files && data.files.length) {
            setTimeout(() => {
              const firstUrl = data.files[0].url;
              const thumbs = document.querySelectorAll('#mediaGrid .media-thumb');
              thumbs.forEach(th => {
                const imgEl = th.querySelector('img');
                if (imgEl && imgEl.src.endsWith(firstUrl)) {
                  highlightMedia({ url: firstUrl, title: data.files[0].original || '', alt: '' }, th);
                }
              });
            }, 400);
          }
        });
    }
  </script>


  </body>

  </html>