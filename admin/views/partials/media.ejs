<!-- ─── MEDIA MODAL ──────────────────────────────────────────────────── -->
<div class="modal fade" id="mediaModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">

      <div class="modal-header">
        <ul class="nav nav-tabs border-0 mb-0">
          <li class="nav-item">
            <a class="nav-link active" href="#" onclick="showMediaTab('library');return false;">Media Library</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="#" onclick="showMediaTab('upload');return false;">Upload Files</a>
          </li>
        </ul>
        <button type="button" class="btn-close ms-auto" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body p-0" style="min-height:500px;">
        <div class="d-flex h-100">

          <!-- LEFT: grid -->
          <div class="flex-grow-1 p-3" style="overflow-y:auto; width: 200%;">

            <!-- Library Tab -->
            <div id="mediaLibraryTab">
              <div id="mediaGrid" class="d-flex flex-wrap gap-2"></div>
            </div>

            <!-- Upload Tab -->
            <div id="mediaUploadTab" style="display:none;" class="py-4 text-center">
              <div class="border rounded p-5 bg-light">
                <i class="mb-3 d-block" style="font-size:40px;">📁</i>
                <p class="mb-3 text-muted">Drop files here or click to select</p>
                <input type="file" id="mediaUploadInput" multiple accept="image/*" class="form-control mb-3" />
                <button class="btn btn-primary rounded-pill px-4" onclick="uploadMedia()">Upload</button>
              </div>
            </div>

          </div>

          <!-- RIGHT: selected image details -->
          <div id="selectedMediaInfo" class="border-start p-3 bg-light" style="width:660px;display:none;">
            <img id="selectedMediaPreview" src="" class="img-fluid rounded mb-3 border d-block mx-auto"
              style="width:60%;" />
            <div class="mb-2">
              <label class="form-label small fw-semibold mb-1">Title</label>
              <input type="text" id="selectedMediaTitle" class="form-control form-control-sm"
                placeholder="Image title" />
            </div>
            <div class="mb-3">
              <label class="form-label small fw-semibold mb-1">Alt Text</label>
              <input type="text" id="selectedMediaAlt" class="form-control form-control-sm" placeholder="Alt text" />
            </div>
          </div>

        </div>
      </div>

      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnInsertMedia" disabled onclick="insertSelectedMedia()">
          Insert Selected
        </button>
      </div>

    </div>
  </div>
</div>
<!-- /MEDIA MODAL -->